# ClickUp API Configuration
CLICKUP_API_KEY=your_api_key_here
CLICKUP_TEAM_ID=your_team_id
CLICKUP_SPACE_ID=your_space_id

# Server Configuration
PORT=3001
NODE_ENV=development

# Agent Configuration
# Max tasks per member before flagging overload
MAX_TASKS_PER_MEMBER=5
# SLA in hours for task completion
DEFAULT_SLA_HOURS=48
# How often to check for overdue tasks (in minutes)
SLA_CHECK_INTERVAL_MINUTES=30
